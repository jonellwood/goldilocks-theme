    "tab.hoverBackground": "#2a3040",
    "tab.hoverForeground": "#c0c8d8",
    "tab.border": "#1e2330",
    "tab.unfocusedActiveBackground": "#2a3040",
    "tab.unfocusedActiveForeground": "#b0bace",
    "panel.background": "#252b38",
    "panel.border": "#1e2330",
    "panelTitle.activeBorder": "#f0a84a",
