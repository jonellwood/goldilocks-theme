    "breadcrumb.foreground": "#8491a3",
    "breadcrumb.focusForeground": "#bec6d7",
    "breadcrumb.activeSelectionForeground": "#d8dfec",
    "breadcrumbPicker.background": "#4b505b",
    "widget.shadow": "#383b4480",
    "editorWidget.background": "#4b505b",
    "editorWidget.border": "#5c6575",
    "editorWidget.foreground": "#bec6d7",
    "editorSuggestWidget.background": "#4b505b",
    "editorSuggestWidget.border": "#5c6575",
    "editorSuggestWidget.foreground": "#cbd5df",
    "editorSuggestWidget.highlightForeground": "#f3b76a",
    "editorSuggestWidget.selectedBackground": "#5c657c",
    "editorHoverWidget.background": "#4b505b",
    "editorHoverWidget.border": "#5c6575",
    "debugToolBar.background": "#454a54",
    "debugIcon.breakpointForeground": "#e5868d",
    "debugIcon.breakpointDisabledForeground": "#846f7c",
    "editor.stackFrameHighlightBackground": "#d2b76b20",
    "editor.focusedStackFrameHighlightBackground": "#77af8820",
    "gitDecoration.addedResourceForeground": "#77af88",
    "gitDecoration.modifiedResourceForeground": "#d2b76b",
    "gitDecoration.deletedResourceForeground": "#e5868d",
    "gitDecoration.untrackedResourceForeground": "#90c9a2",
    "gitDecoration.ignoredResourceForeground": "#6a7282",
    "gitDecoration.conflictingResourceForeground": "#cb9077",
    "gitDecoration.stageModifiedResourceForeground": "#d2b76b",
    "gitDecoration.stageDeletedResourceForeground": "#e5868d",
    "focusBorder": "#6a84ac80",
    "contrastBorder": "#00000000",
    "widget.border": "#5c6575",
    "settings.headerForeground": "#bec6d7",
    "settings.modifiedItemIndicator": "#f3b76a",
    "settings.dropdownBackground": "#454a54",
    "settings.checkboxBackground": "#454a54",
    "settings.textInputBackground": "#454a54",
    "settings.numberInputBackground": "#454a54"
  },
  "tokenColors": [
    {
      "name": "Comments",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#778989",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Doc Comments",
      "scope": [
        "comment.block.documentation",
        "comment.line.double-slash.documentation"
      ],
      "settings": {
        "foreground": "#709190",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Strings",
      "scope": [
        "string",
        "string.quoted",
        "string.template"
      ],
      "settings": {
        "foreground": "#9ec489"
      }
    },
    {
      "name": "String Escape Sequences",
      "scope": [
        "constant.character.escape",
        "string.regexp"
      ],
      "settings": {
        "foreground": "#90d2b1"
      }
    },
    {
      "name": "Template Literal Expressions",
      "scope": [
        "punctuation.definition.template-expression",
        "punctuation.section.embedded"
      ],
      "settings": {
        "foreground": "#d2b17c"
      }
    },
    {
      "name": "Numbers",
      "scope": [
        "constant.numeric",
        "constant.numeric.decimal",
        "constant.numeric.integer",
        "constant.numeric.float",
        "constant.numeric.hex",
        "constant.numeric.octal"
      ],
      "settings": {
        "foreground": "#cbaa82"
      }
    },
    {
      "name": "Built-in Constants",
      "scope": [
        "constant.language",
        "constant.other"
      ],
      "settings": {
        "foreground": "#d89d75"
      }
    },
    {
      "name": "Boolean",
      "scope": [
        "constant.language.boolean"
      ],
      "settings": {
        "foreground": "#d89d75",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Null / Undefined",
      "scope": [
        "constant.language.null",
        "constant.language.undefined",
        "constant.language.nan"
      ],
      "settings": {
        "foreground": "#b1907c",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Keywords",
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.other",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#a396cb",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Control Flow",
      "scope": [
        "keyword.control.flow",
        "keyword.control.if",
        "keyword.control.else",
        "keyword.control.for",
        "keyword.control.while",
        "keyword.control.return",
        "keyword.control.loop",
        "keyword.control.switch",
        "keyword.control.case",
        "keyword.control.break",
        "keyword.control.continue",
        "keyword.control.import",
        "keyword.control.export",
        "keyword.control.from",
        "keyword.control.as",
        "keyword.control.of",
        "keyword.control.in"
      ],
      "settings": {
        "foreground": "#b190d8",
        "fontStyle": "bold"
      }
    },
    {
      "name": "New / Delete / Instanceof",
      "scope": [
        "keyword.operator.new",
        "keyword.operator.delete",
        "keyword.operator.instanceof",
        "keyword.operator.typeof",
        "keyword.operator.void"
      ],
      "settings": {
        "foreground": "#c49de5"
      }
    },
    {
      "name": "Storage Type",
      "scope": [
        "storage.type"
      ],
      "settings": {
        "foreground": "#90aadf",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Storage Type – function/class",
      "scope": [
        "storage.type.function",
        "storage.type.class",
        "storage.type.arrow"
      ],
      "settings": {
        "foreground": "#89a3d5",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Function Names",
      "scope": [
        "entity.name.function",
        "meta.function-call entity.name.function"
      ],
      "settings": {
        "foreground": "#89c4d8"
      }
    },
    {
      "name": "Function Call",
      "scope": [
        "meta.function-call.generic",
        "support.function"
      ],
      "settings": {
        "foreground": "#82bed2"
      }
    },
    {
      "name": "Method Definition",
      "scope": [
        "meta.definition.method entity.name.function",
        "entity.name.function.constructor"
      ],
      "settings": {
        "foreground": "#96d2e5",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Variables",
      "scope": [
        "variable",
        "variable.other",
        "variable.other.readwrite",
        "variable.other.object"
      ],
      "settings": {
        "foreground": "#d2dce5"
      }
    },
    {
      "name": "Variable – this / self",
      "scope": [
        "variable.language.this",
        "variable.language.self",
        "variable.language.super"
      ],
      "settings": {
        "foreground": "#c4aad5",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Parameters",
      "scope": [
        "variable.parameter"
      ],
      "settings": {
        "foreground": "#c4d2df",
        "fontStyle": "italic"
      }
    },
    {
      "name": "PHP Variable",
      "scope": [
        "variable.other.php",
        "variable.other.global.php",
        "variable.other.global.safer.php",
        "variable.other.normal.php",
        "punctuation.definition.variable.php"
      ],
      "settings": {
        "foreground": "#d2dce5"
      }
    },
    {
      "name": "Class Names",
      "scope": [
        "entity.name.class",
        "entity.name.type.class",
        "entity.name.type.interface",
        "entity.name.type.enum",
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#dfcb82"
      }
    },
    {
      "name": "Type Annotations",
      "scope": [
        "entity.name.type",
        "support.type",
        "meta.type.annotation",
        "meta.return.type"
      ],
      "settings": {
        "foreground": "#d2c475"
      }
    },
    {
      "name": "Primitive Types",
      "scope": [
        "support.type.primitive",
        "keyword.type",
        "storage.type.numeric",
        "storage.type.string",
        "storage.type.boolean",
        "storage.type.void"
      ],
      "settings": {
        "foreground": "#c4b768"
      }
    },
    {
      "name": "Operators",
      "scope": [
        "keyword.operator",
        "keyword.operator.assignment",
        "keyword.operator.arithmetic",
        "keyword.operator.comparison",
        "keyword.operator.logical",
        "keyword.operator.bitwise",
        "keyword.operator.ternary"
      ],
      "settings": {
        "foreground": "#b1bed2"
      }
    },
    {
      "name": "Arrow Operator",
      "scope": [
        "keyword.operator.arrow",
        "storage.type.function.arrow"
      ],
      "settings": {
        "foreground": "#b7c4d8"
      }
    },
    {
      "name": "Punctuation",
      "scope": [
        "punctuation",
        "meta.brace",
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.definition.block",
        "punctuation.section.block"
      ],
      "settings": {
        "foreground": "#919daa"
      }
    },
    {
      "name": "Brackets & Parens",
      "scope": [
        "punctuation.definition.parameters",
        "punctuation.definition.arguments",
        "meta.brace.round",
        "meta.brace.square"
      ],
      "settings": {
        "foreground": "#9eaab7"
      }
    },
    {
      "name": "Object Properties",
      "scope": [
        "variable.other.property",
        "variable.other.object.property",
        "support.type.property-name",
        "meta.object-literal.key"
      ],
      "settings": {
        "foreground": "#becbdf"
      }
    },
    {
      "name": "Member Access",
      "scope": [
        "variable.other.member",
        "variable.other.readwrite.member"
      ],
      "settings": {
        "foreground": "#becbdf"
      }
    },
    {
      "name": "HTML Tags",
      "scope": [
        "entity.name.tag",
        "meta.tag"
      ],
      "settings": {
        "foreground": "#89a3cb"
      }
    },
    {
      "name": "HTML Attribute Names",
      "scope": [
        "entity.other.attribute-name",
        "meta.tag.attributes"
      ],
      "settings": {
        "foreground": "#a3c4df"
      }
    },
    {
      "name": "HTML Attribute Values",
      "scope": [
        "string.quoted.double.html",
        "string.quoted.single.html",
        "meta.attribute-with-value.html"
      ],
      "settings": {
        "foreground": "#9ec489"
      }
    },
    {
      "name": "HTML Doctype",
      "scope": [
        "meta.tag.sgml",
        "entity.name.tag.doctype"
      ],
      "settings": {
        "foreground": "#6f7c96",
        "fontStyle": "italic"
      }
    },
    {
      "name": "HTML Entities",
      "scope": [
        "constant.character.entity.html",
        "punctuation.definition.entity.html"
      ],
      "settings": {
        "foreground": "#90d2b1"
      }
    },
    {
      "name": "HTML Self Closing Tags",
      "scope": [
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#6f8296"
      }
    },
    {
      "name": "CSS Selectors",
      "scope": [
        "entity.name.tag.css",
        "entity.other.attribute-name.class.css",
        "entity.other.attribute-name.id.css",
        "entity.other.attribute-name.pseudo-class.css",
        "entity.other.attribute-name.pseudo-element.css"
      ],
      "settings": {
        "foreground": "#9ec4d8"
      }
    },
    {
      "name": "CSS Properties",
      "scope": [
        "support.type.property-name.css",
        "meta.property-name.css"
      ],
      "settings": {
        "foreground": "#a3bed2"
      }
    },
    {
      "name": "CSS Values",
      "scope": [
        "meta.property-value.css",
        "support.constant.property-value.css",
        "constant.other.color.rgb-value.css"
      ],
      "settings": {
        "foreground": "#b7d2aa"
      }
    },
    {
      "name": "CSS Units",
      "scope": [
        "keyword.other.unit.css",
        "constant.numeric.css"
      ],
      "settings": {
        "foreground": "#cbaa82"
      }
    },
    {
      "name": "CSS At-rules",
      "scope": [
        "keyword.control.at-rule",
        "keyword.control.at-rule.media",
        "keyword.control.at-rule.keyframes"
      ],
      "settings": {
        "foreground": "#b190d8",
        "fontStyle": "bold"
      }
    },
    {
      "name": "CSS Colors",
      "scope": [
        "constant.other.color.rgb-value",
        "support.constant.color"
      ],
      "settings": {
        "foreground": "#c4b768"
      }
    },
    {
      "name": "CSS Important",
      "scope": [
        "keyword.other.important.css"
      ],
      "settings": {
        "foreground": "#e5868d",
        "fontStyle": "bold"
      }
    },
    {
      "name": "JS/TS Import / Export Keywords",
      "scope": [
        "keyword.control.import.js",
        "keyword.control.export.js",
        "keyword.control.from.js",
        "keyword.control.import.ts",
        "keyword.control.export.ts",
        "keyword.control.from.ts"
      ],
      "settings": {
        "foreground": "#b190d8",
        "fontStyle": "bold"
      }
    },
    {
      "name": "JS/TS Decorators",
      "scope": [
        "meta.decorator",
        "punctuation.decorator"
      ],
      "settings": {
        "foreground": "#d2b17c",
        "fontStyle": "italic"
      }
    },
    {
      "name": "TS Interface / Type",
      "scope": [
        "keyword.other.type.ts",
        "keyword.other.interface.ts"
      ],
      "settings": {
        "foreground": "#a396cb",
        "fontStyle": "bold"
      }
    },
    {
      "name": "JS Console / Built-ins",
      "scope": [
        "support.type.object.console.js",
        "support.type.object.module.js",
        "variable.language.arguments.js"
      ],
      "settings": {
        "foreground": "#82bed2"
      }
    },
    {
      "name": "Vue Component Tags",
      "scope": [
        "entity.name.tag.html.vue"
      ],
      "settings": {
        "foreground": "#90cbb1",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Vue Directives",
      "scope": [
        "entity.other.attribute-name.html.vue",
        "keyword.control.conditional.vue",
        "entity.other.attribute-name.pseudo-class.vue"
      ],
      "settings": {
        "foreground": "#d2b17c"
      }
    },
    {
      "name": "Vue Template Delimiters",
      "scope": [
        "punctuation.section.embedded.begin.mustache",
        "punctuation.section.embedded.end.mustache"
      ],
      "settings": {
        "foreground": "#d89d75",
        "fontStyle": "bold"
      }
    },
    {
      "name": "PHP Tags",
      "scope": [
        "punctuation.section.embedded.begin.php",
        "punctuation.section.embedded.end.php"
      ],
      "settings": {
        "foreground": "#c49de5",
        "fontStyle": "bold"
      }
    },
    {
      "name": "PHP Functions",
      "scope": [
        "support.function.php",
        "support.function.string.php"
      ],
      "settings": {
        "foreground": "#89c4d8"
      }
    },
    {
      "name": "PHP Namespaces / Use",
      "scope": [
        "storage.type.namespace.php",
        "keyword.other.namespace.php",
        "keyword.other.use.php"
      ],
      "settings": {
        "foreground": "#a396cb",
        "fontStyle": "bold"
      }
    },
    {
