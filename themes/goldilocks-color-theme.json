    "input.placeholderForeground": "#6a7590",
    "inputValidation.errorBackground": "#774f4f",
    "inputValidation.errorBorder": "#cb6f6f",
    "inputValidation.warningBackground": "#6f5c42",
    "inputValidation.warningBorder": "#be9661",
    "dropdown.background": "#454a54",
    "dropdown.border": "#5c6575",
    "dropdown.foreground": "#bec6d7",
    "button.background": "#6a84ac",
    "button.foreground": "#e3f1ff",
    "button.hoverBackground": "#7791b9",
    "button.secondaryBackground": "#5c6575",
    "button.secondaryForeground": "#bec6d7",
    "scrollbar.shadow": "#2d2d2d30",
    "scrollbarSlider.background": "#6a7590a0",
    "scrollbarSlider.hoverBackground": "#77829db0",
    "scrollbarSlider.activeBackground": "#8490b1c0",
    "minimap.background": "#4d525c",
    "minimap.selectionHighlight": "#6a779180",
    "minimap.findMatchHighlight": "#d2944760",
    "minimapGutter.addedBackground": "#77af88",
    "minimapGutter.modifiedBackground": "#d2b76b",
    "minimapGutter.deletedBackground": "#c97575",
    "diffEditor.insertedTextBackground": "#77af8818",
    "diffEditor.removedTextBackground": "#c9757518",
    "diffEditor.insertedLineBackground": "#77af8812",
    "diffEditor.removedLineBackground": "#c9757512",
    "notifications.background": "#4b505b",
    "notifications.foreground": "#bec6d7",
    "notifications.border": "#454a54",
    "notificationToast.border": "#5c6575",
    "notificationsInfoIcon.foreground": "#7a9ecb",
    "notificationsWarningIcon.foreground": "#d2b76b",
    "notificationsErrorIcon.foreground": "#e5868d",
    "peekView.border": "#6a84ac",
    "peekViewEditor.background": "#494e5b",
    "peekViewEditor.matchHighlightBackground": "#d2944740",
    "peekViewResult.background": "#454a54",
    "peekViewResult.fileForeground": "#b1becb",
    "peekViewResult.lineForeground": "#919eac",
    "peekViewResult.matchHighlightBackground": "#d2944740",
    "peekViewResult.selectionBackground": "#5c6a82",
    "peekViewResult.selectionForeground": "#d8dfec",
    "peekViewTitle.background": "#454a54",
    "peekViewTitleDescription.foreground": "#8491a3",
    "peekViewTitleLabel.foreground": "#cbd5df",
