    "panelTitle.inactiveForeground": "#5a6a80",
    "terminal.background": "#252b38",
    "terminal.foreground": "#c8d4e0",
    "terminal.ansiBlack": "#2e3440",
    "terminal.ansiRed": "#e06c75",
    "terminal.ansiGreen": "#5a9e6f",
    "terminal.ansiYellow": "#c9a84c",
