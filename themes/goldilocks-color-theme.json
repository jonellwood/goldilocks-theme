    "terminal.ansiMagenta": "#9a7ab0",
    "terminal.ansiCyan": "#4e9aaa",
    "terminal.ansiWhite": "#c8d4e0",
    "terminal.ansiBrightBlack": "#4a5468",
    "terminal.ansiBrightRed": "#f08090",
    "terminal.ansiBrightGreen": "#78be8e",
    "terminal.ansiBrightYellow": "#dfc070",
    "terminal.ansiBrightBlue": "#7aaad8",
    "terminal.ansiBrightMagenta": "#b898cc",
    "terminal.ansiBrightCyan": "#68b8c8",
    "terminal.ansiBrightWhite": "#e8f0f8",
    "terminal.selectionBackground": "#4a5a7a60",
    "terminalCursor.foreground": "#f0a84a",
    "input.background": "#1e2330",
    "input.border": "#3a4458",
    "input.foreground": "#c0ccd8",
    "input.placeholderForeground": "#4a5878",
    "inputValidation.errorBackground": "#5a2a2a",
    "inputValidation.errorBorder": "#c05050",
    "inputValidation.warningBackground": "#503a1a",
    "inputValidation.warningBorder": "#b08040",
    "dropdown.background": "#1e2330",
    "dropdown.border": "#3a4458",
    "dropdown.foreground": "#b0bace",
    "button.background": "#4a6a9a",
    "button.foreground": "#ddeeff",
    "button.hoverBackground": "#5a7aaa",
    "button.secondaryBackground": "#3a4458",
    "button.secondaryForeground": "#b0bace",
    "scrollbar.shadow": "#00000030",
    "scrollbarSlider.background": "#4a5878a0",
    "scrollbarSlider.hoverBackground": "#5a6888b0",
    "scrollbarSlider.activeBackground": "#6a78a0c0",
    "minimap.background": "#272d3a",
    "minimap.selectionHighlight": "#4a5a7a80",
    "minimap.findMatchHighlight": "#c87d2060",
    "minimapGutter.addedBackground": "#5a9e6f",
    "minimapGutter.modifiedBackground": "#c9a84c",
    "minimapGutter.deletedBackground": "#be5858",
    "diffEditor.insertedTextBackground": "#5a9e6f18",
    "diffEditor.removedTextBackground": "#be585818",
    "diffEditor.insertedLineBackground": "#5a9e6f12",
    "diffEditor.removedLineBackground": "#be585812",
    "notifications.background": "#252b38",
    "notifications.foreground": "#b0bace",
    "notifications.border": "#1e2330",
    "notificationToast.border": "#3a4458",
    "notificationsInfoIcon.foreground": "#5e8ac0",
    "notificationsWarningIcon.foreground": "#c9a84c",
    "notificationsErrorIcon.foreground": "#e06c75",
    "peekView.border": "#4a6a9a",
    "peekViewEditor.background": "#222838",
    "peekViewEditor.matchHighlightBackground": "#c87d2040",
    "peekViewResult.background": "#1e2330",
    "peekViewResult.fileForeground": "#a0b0c0",
    "peekViewResult.lineForeground": "#7a8a9a",
    "peekViewResult.matchHighlightBackground": "#c87d2040",
    "peekViewResult.selectionBackground": "#3a4a68",
    "peekViewResult.selectionForeground": "#d0d8e8",
    "peekViewTitle.background": "#1e2330",
    "peekViewTitleDescription.foreground": "#6a7a90",
    "peekViewTitleLabel.foreground": "#c0ccd8",
    "breadcrumb.background": "#2e3440",
    "breadcrumb.foreground": "#6a7a90",
    "breadcrumb.focusForeground": "#b0bace",
    "breadcrumb.activeSelectionForeground": "#d0d8e8",
    "breadcrumbPicker.background": "#252b38",
    "widget.shadow": "#0e121c80",
    "editorWidget.background": "#252b38",
    "editorWidget.border": "#3a4458",
    "editorWidget.foreground": "#b0bace",
    "editorSuggestWidget.background": "#252b38",
    "editorSuggestWidget.border": "#3a4458",
    "editorSuggestWidget.foreground": "#c0ccd8",
    "editorSuggestWidget.highlightForeground": "#f0a84a",
    "editorSuggestWidget.selectedBackground": "#3a4460",
    "editorHoverWidget.background": "#252b38",
    "editorHoverWidget.border": "#3a4458",
    "debugToolBar.background": "#1e2330",
    "debugIcon.breakpointForeground": "#e06c75",
    "debugIcon.breakpointDisabledForeground": "#6a5060",
    "editor.stackFrameHighlightBackground": "#c9a84c20",
    "editor.focusedStackFrameHighlightBackground": "#5a9e6f20",
    "gitDecoration.addedResourceForeground": "#5a9e6f",
    "gitDecoration.modifiedResourceForeground": "#c9a84c",
    "gitDecoration.deletedResourceForeground": "#e06c75",
    "gitDecoration.untrackedResourceForeground": "#78be8e",
    "gitDecoration.ignoredResourceForeground": "#4a5468",
    "gitDecoration.conflictingResourceForeground": "#c0785a",
    "gitDecoration.stageModifiedResourceForeground": "#c9a84c",
    "gitDecoration.stageDeletedResourceForeground": "#e06c75",
    "focusBorder": "#4a6a9a80",
    "contrastBorder": "#00000000",
    "widget.border": "#3a4458",
    "settings.headerForeground": "#b0bace",
    "settings.modifiedItemIndicator": "#f0a84a",
    "settings.dropdownBackground": "#1e2330",
    "settings.checkboxBackground": "#1e2330",
    "settings.textInputBackground": "#1e2330",
    "settings.numberInputBackground": "#1e2330"
  },
  "tokenColors": [
    {
      "name": "Comments",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#5a7070",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Doc Comments",
      "scope": [
        "comment.block.documentation",
        "comment.line.double-slash.documentation"
      ],
      "settings": {
        "foreground": "#527a78",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Strings",
      "scope": [
        "string",
        "string.quoted",
        "string.template"
      ],
      "settings": {
        "foreground": "#8ab870"
      }
    },
    {
      "name": "String Escape Sequences",
      "scope": [
        "constant.character.escape",
        "string.regexp"
      ],
      "settings": {
        "foreground": "#78c8a0"
      }
    },
    {
      "name": "Template Literal Expressions",
      "scope": [
        "punctuation.definition.template-expression",
        "punctuation.section.embedded"
      ],
      "settings": {
        "foreground": "#c8a060"
      }
    },
    {
      "name": "Numbers",
      "scope": [
        "constant.numeric",
        "constant.numeric.decimal",
        "constant.numeric.integer",
        "constant.numeric.float",
        "constant.numeric.hex",
        "constant.numeric.octal"
      ],
      "settings": {
        "foreground": "#c09868"
      }
    },
    {
      "name": "Built-in Constants",
      "scope": [
        "constant.language",
        "constant.other"
      ],
      "settings": {
        "foreground": "#d08858"
      }
    },
    {
      "name": "Boolean",
      "scope": [
        "constant.language.boolean"
      ],
      "settings": {
        "foreground": "#d08858",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Null / Undefined",
      "scope": [
        "constant.language.null",
        "constant.language.undefined",
        "constant.language.nan"
      ],
      "settings": {
        "foreground": "#a07860",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Keywords",
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.other",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#9080c0",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Control Flow",
      "scope": [
        "keyword.control.flow",
        "keyword.control.if",
        "keyword.control.else",
        "keyword.control.for",
        "keyword.control.while",
        "keyword.control.return",
        "keyword.control.loop",
        "keyword.control.switch",
        "keyword.control.case",
        "keyword.control.break",
        "keyword.control.continue",
        "keyword.control.import",
        "keyword.control.export",
        "keyword.control.from",
        "keyword.control.as",
        "keyword.control.of",
        "keyword.control.in"
      ],
      "settings": {
        "foreground": "#a078d0",
        "fontStyle": "bold"
      }
    },
    {
      "name": "New / Delete / Instanceof",
      "scope": [
        "keyword.operator.new",
        "keyword.operator.delete",
        "keyword.operator.instanceof",
        "keyword.operator.typeof",
        "keyword.operator.void"
      ],
      "settings": {
        "foreground": "#b888e0"
      }
    },
    {
      "name": "Storage Type",
      "scope": [
        "storage.type"
      ],
      "settings": {
        "foreground": "#7898d8",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Storage Type – function/class",
      "scope": [
        "storage.type.function",
        "storage.type.class",
        "storage.type.arrow"
      ],
      "settings": {
        "foreground": "#7090cc",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Function Names",
      "scope": [
        "entity.name.function",
        "meta.function-call entity.name.function"
      ],
      "settings": {
        "foreground": "#70b8d0"
      }
    },
    {
      "name": "Function Call",
      "scope": [
        "meta.function-call.generic",
        "support.function"
      ],
      "settings": {
        "foreground": "#68b0c8"
      }
    },
    {
      "name": "Method Definition",
      "scope": [
        "meta.definition.method entity.name.function",
        "entity.name.function.constructor"
      ],
      "settings": {
        "foreground": "#80c8e0",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Variables",
      "scope": [
        "variable",
        "variable.other",
        "variable.other.readwrite",
        "variable.other.object"
      ],
      "settings": {
        "foreground": "#c8d4e0"
      }
    },
    {
      "name": "Variable – this / self",
      "scope": [
        "variable.language.this",
        "variable.language.self",
        "variable.language.super"
      ],
      "settings": {
        "foreground": "#b898cc",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Parameters",
      "scope": [
        "variable.parameter"
      ],
      "settings": {
        "foreground": "#b8c8d8",
        "fontStyle": "italic"
      }
    },
    {
      "name": "PHP Variable",
      "scope": [
        "variable.other.php",
        "variable.other.global.php",
        "variable.other.global.safer.php",
        "variable.other.normal.php",
        "punctuation.definition.variable.php"
      ],
      "settings": {
        "foreground": "#c8d4e0"
      }
    },
    {
      "name": "Class Names",
      "scope": [
        "entity.name.class",
        "entity.name.type.class",
        "entity.name.type.interface",
        "entity.name.type.enum",
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#d8c068"
      }
    },
    {
      "name": "Type Annotations",
      "scope": [
        "entity.name.type",
        "support.type",
        "meta.type.annotation",
        "meta.return.type"
      ],
      "settings": {
        "foreground": "#c8b858"
      }
    },
    {
      "name": "Primitive Types",
      "scope": [
        "support.type.primitive",
        "keyword.type",
        "storage.type.numeric",
        "storage.type.string",
        "storage.type.boolean",
        "storage.type.void"
      ],
      "settings": {
        "foreground": "#b8a848"
      }
    },
    {
      "name": "Operators",
      "scope": [
        "keyword.operator",
        "keyword.operator.assignment",
        "keyword.operator.arithmetic",
        "keyword.operator.comparison",
        "keyword.operator.logical",
        "keyword.operator.bitwise",
        "keyword.operator.ternary"
      ],
      "settings": {
        "foreground": "#a0b0c8"
      }
    },
    {
      "name": "Arrow Operator",
      "scope": [
        "keyword.operator.arrow",
        "storage.type.function.arrow"
      ],
      "settings": {
        "foreground": "#a8b8d0"
      }
    },
    {
      "name": "Punctuation",
      "scope": [
        "punctuation",
        "meta.brace",
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.definition.block",
        "punctuation.section.block"
      ],
      "settings": {
        "foreground": "#7a8898"
      }
    },
    {
      "name": "Brackets & Parens",
      "scope": [
        "punctuation.definition.parameters",
        "punctuation.definition.arguments",
        "meta.brace.round",
        "meta.brace.square"
      ],
      "settings": {
        "foreground": "#8a98a8"
      }
    },
    {
      "name": "Object Properties",
      "scope": [
        "variable.other.property",
        "variable.other.object.property",
        "support.type.property-name",
        "meta.object-literal.key"
      ],
      "settings": {
        "foreground": "#b0c0d8"
      }
    },
    {
      "name": "Member Access",
      "scope": [
        "variable.other.member",
        "variable.other.readwrite.member"
      ],
      "settings": {
        "foreground": "#b0c0d8"
      }
    },
    {
      "name": "HTML Tags",
      "scope": [
        "entity.name.tag",
        "meta.tag"
      ],
      "settings": {
        "foreground": "#7090c0"
      }
    },
    {
      "name": "HTML Attribute Names",
      "scope": [
        "entity.other.attribute-name",
        "meta.tag.attributes"
      ],
      "settings": {
        "foreground": "#90b8d8"
      }
    },
    {
      "name": "HTML Attribute Values",
      "scope": [
        "string.quoted.double.html",
        "string.quoted.single.html",
        "meta.attribute-with-value.html"
      ],
      "settings": {
        "foreground": "#8ab870"
      }
    },
    {
      "name": "HTML Doctype",
      "scope": [
        "meta.tag.sgml",
        "entity.name.tag.doctype"
      ],
      "settings": {
        "foreground": "#506080",
        "fontStyle": "italic"
      }
    },
    {
      "name": "HTML Entities",
      "scope": [
        "constant.character.entity.html",
        "punctuation.definition.entity.html"
      ],
      "settings": {
        "foreground": "#78c8a0"
      }
    },
    {
      "name": "HTML Self Closing Tags",
      "scope": [
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#506880"
      }
    },
    {
      "name": "CSS Selectors",
      "scope": [
        "entity.name.tag.css",
        "entity.other.attribute-name.class.css",
        "entity.other.attribute-name.id.css",
        "entity.other.attribute-name.pseudo-class.css",
        "entity.other.attribute-name.pseudo-element.css"
      ],
      "settings": {
        "foreground": "#8ab8d0"
      }
    },
    {
      "name": "CSS Properties",
      "scope": [
        "support.type.property-name.css",
        "meta.property-name.css"
      ],
      "settings": {
        "foreground": "#90b0c8"
      }
    },
    {
      "name": "CSS Values",
      "scope": [
        "meta.property-value.css",
        "support.constant.property-value.css",
        "constant.other.color.rgb-value.css"
      ],
      "settings": {
        "foreground": "#a8c898"
      }
    },
    {
      "name": "CSS Units",
      "scope": [
        "keyword.other.unit.css",
        "constant.numeric.css"
      ],
      "settings": {
        "foreground": "#c09868"
      }
    },
    {
      "name": "CSS At-rules",
      "scope": [
        "keyword.control.at-rule",
        "keyword.control.at-rule.media",
        "keyword.control.at-rule.keyframes"
      ],
      "settings": {
        "foreground": "#a078d0",
        "fontStyle": "bold"
      }
    },
    {
      "name": "CSS Colors",
      "scope": [
        "constant.other.color.rgb-value",
        "support.constant.color"
      ],
      "settings": {
        "foreground": "#b8a848"
      }
    },
    {
      "name": "CSS Important",
      "scope": [
        "keyword.other.important.css"
      ],
      "settings": {
        "foreground": "#e06c75",
        "fontStyle": "bold"
      }
    },
    {
      "name": "JS/TS Import / Export Keywords",
      "scope": [
        "keyword.control.import.js",
        "keyword.control.export.js",
        "keyword.control.from.js",
        "keyword.control.import.ts",
        "keyword.control.export.ts",
        "keyword.control.from.ts"
      ],
      "settings": {
        "foreground": "#a078d0",
        "fontStyle": "bold"
      }
    },
    {
      "name": "JS/TS Decorators",
      "scope": [
        "meta.decorator",
        "punctuation.decorator"
      ],
      "settings": {
        "foreground": "#c8a060",
        "fontStyle": "italic"
      }
    },
    {
      "name": "TS Interface / Type",
      "scope": [
        "keyword.other.type.ts",
        "keyword.other.interface.ts"
      ],
      "settings": {
        "foreground": "#9080c0",
        "fontStyle": "bold"
      }
    },
    {
      "name": "JS Console / Built-ins",
      "scope": [
        "support.type.object.console.js",
        "support.type.object.module.js",
        "variable.language.arguments.js"
      ],
      "settings": {
        "foreground": "#68b0c8"
      }
    },
    {
      "name": "Vue Component Tags",
      "scope": [
        "entity.name.tag.html.vue"
      ],
      "settings": {
        "foreground": "#78c0a0",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Vue Directives",
      "scope": [
        "entity.other.attribute-name.html.vue",
        "keyword.control.conditional.vue",
        "entity.other.attribute-name.pseudo-class.vue"
      ],
      "settings": {
        "foreground": "#c8a060"
      }
    },
    {
      "name": "Vue Template Delimiters",
      "scope": [
        "punctuation.section.embedded.begin.mustache",
        "punctuation.section.embedded.end.mustache"
      ],
      "settings": {
        "foreground": "#d08858",
        "fontStyle": "bold"
      }
    },
    {
      "name": "PHP Tags",
      "scope": [
        "punctuation.section.embedded.begin.php",
        "punctuation.section.embedded.end.php"
      ],
      "settings": {
        "foreground": "#b888e0",
        "fontStyle": "bold"
      }
    },
    {
      "name": "PHP Functions",
      "scope": [
        "support.function.php",
        "support.function.string.php"
      ],
      "settings": {
        "foreground": "#70b8d0"
      }
